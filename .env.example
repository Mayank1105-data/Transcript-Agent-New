# ──────────────────────────────────────────────────────────────
# Audio-to-DevOps Pipeline — Configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────

# ── Gemini API Key ──
# Used for transcription, requirements structuring & refinement
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash


# ── Azure DevOps ──
DEVOPS_ORG_URL=https://dev.azure.com/advicon
DEVOPS_PAT=your-personal-access-token
DEVOPS_PROJECT=Rajesh AI
DEVOPS_WORK_ITEM_TYPE=User Story

# ── Server Settings ──
PORT=5000
